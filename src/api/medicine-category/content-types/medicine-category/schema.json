{
  "kind": "collectionType",
  "collectionName": "medicine_categories",
  "info": {
    "singularName": "medicine-category",
    "pluralName": "medicine-categories",
    "displayName": "MEDICINE_CATEGORIES"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "CategoryName": {
      "type": "string",
      "unique": true
    },
    "Description": {
      "type": "blocks"
    },
    "StorageRequirements": {
      "type": "text"
    },
    "RequiresPrescription": {
      "type": "boolean",
      "default": false
    },
    "ControlledSubstance": {
      "type": "boolean",
      "default": false
    },
    "medicines": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::medicine.medicine",
      "mappedBy": "medicine_category"
    }
  }
}
