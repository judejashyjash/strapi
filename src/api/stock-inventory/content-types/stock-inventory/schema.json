{
  "kind": "collectionType",
  "collectionName": "stock_inventories",
  "info": {
    "singularName": "stock-inventory",
    "pluralName": "stock-inventories",
    "displayName": "STOCK_INVENTORY"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "BatchNumber": {
      "type": "string",
      "required": true
    },
    "QuantityOnHand": {
      "type": "integer",
      "min": 0
    },
    "ExpiryDate": {
      "type": "date",
      "required": true
    },
    "StorageLocation": {
      "type": "string"
    },
    "LastRestockDate": {
      "type": "date"
    },
    "medicine": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::medicine.medicine",
      "inversedBy": "stock_inventories"
    }
  }
}
